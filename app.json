{
  "expo": {
    "scheme": "ikkii",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "output": "static"
    },
    "name": "Ikkii",
    "slug": "mobile",
    "icon": "./icon.png",
    "extra": {
      "eas": {
        "projectId": "d2f33116-a459-4c93-967b-b845c640645e"
      }
    },
    "android": {
      "package": "com.ikkii",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ikkii to access your photos to set your profile picture."
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.ikkii"
    }
  }
}
